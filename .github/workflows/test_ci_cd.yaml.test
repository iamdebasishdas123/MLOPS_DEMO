name: CI

on: 
  push:
    branches: [main]
  pull_request:

jobs:
  linting:
    runs-on: ubuntu-latest # No need for macos here
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.x'
      - name: install flake8
        run: pip install flake8
      - name: run flake8
        run: flake8 ./CI_Demo/app.py

  testing:
    needs: linting
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.9'
      - name: run unit test
        run: python -m unittest discover
